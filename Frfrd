<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quel est ton profil numérique?</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Syne:wght@400;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
–bg: #f5f0e8;
–surface: #ffffff;
–ink: #1c1814;
–muted: #9a9490;
–border: #e0d9ce;
–accent: #c84b2f;
–accent-light: rgba(200,75,47,0.08);
–freq-1: #3d5a80;
–freq-2: #6b8cae;
–freq-3: #e9a825;
–freq-4: #d4732a;
–freq-5: #c84b2f;
}

body {
background: var(–bg);
color: var(–ink);
font-family: ‘Syne’, sans-serif;
min-height: 100vh;
display: flex;
align-items: center;
justify-content: center;
padding: 24px;
position: relative;
}

body::before {
content: ‘’;
position: fixed;
inset: 0;
background:
radial-gradient(ellipse 60% 40% at 10% 20%, rgba(200,75,47,0.07) 0%, transparent 60%),
radial-gradient(ellipse 50% 50% at 90% 80%, rgba(61,90,128,0.07) 0%, transparent 60%),
radial-gradient(ellipse 40% 60% at 50% 50%, rgba(233,168,37,0.04) 0%, transparent 70%);
pointer-events: none;
z-index: 0;
}

.container {
width: 100%;
max-width: 640px;
position: relative;
z-index: 1;
}

/* –– SCREENS –– */
.screen { display: none; }
.screen.active { display: block; animation: fadeUp 0.4s cubic-bezier(0.22,1,0.36,1) both; }

@keyframes fadeUp {
from { opacity: 0; transform: translateY(18px); }
to { opacity: 1; transform: translateY(0); }
}

/* –– CARD –– */
.card {
background: var(–surface);
border: 1px solid var(–border);
padding: 44px 48px;
box-shadow: 0 2px 40px rgba(28,24,20,0.07);
}

@media (max-width: 520px) {
.card { padding: 32px 24px; }
}

/* –– INTRO –– */
.intro-eyebrow {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 20px;
}

.intro-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2.2rem, 7vw, 3.4rem);
line-height: 1.1;
margin-bottom: 20px;
color: var(–ink);
}

.intro-title em {
font-style: italic;
color: var(–accent);
}

.intro-body {
font-size: 0.95rem;
line-height: 1.75;
color: #5a5550;
font-weight: 400;
margin-bottom: 32px;
}

.intro-pills {
display: flex;
flex-wrap: wrap;
gap: 8px;
margin-bottom: 36px;
}

.pill {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 1px;
padding: 6px 14px;
border: 1.5px solid var(–border);
color: var(–muted);
}

.btn-start {
background: var(–ink);
color: var(–bg);
border: none;
font-family: ‘Syne’, sans-serif;
font-weight: 700;
font-size: 14px;
letter-spacing: 1px;
padding: 16px 36px;
cursor: pointer;
transition: all 0.18s;
text-transform: uppercase;
}

.btn-start:hover { background: var(–accent); transform: translateY(-2px); }

/* –– PROGRESS –– */
.progress-wrap {
margin-bottom: 32px;
}

.progress-track {
height: 2px;
background: var(–border);
margin-bottom: 8px;
overflow: hidden;
}

.progress-fill {
height: 100%;
background: var(–accent);
transition: width 0.4s cubic-bezier(0.22,1,0.36,1);
}

.progress-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 2px;
color: var(–muted);
text-transform: uppercase;
}

/* –– QUESTION –– */
.q-type {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 14px;
}

.q-text {
font-family: ‘Playfair Display’, serif;
font-size: clamp(1.3rem, 4vw, 1.75rem);
line-height: 1.3;
color: var(–ink);
margin-bottom: 32px;
}

/* –– CHOICE OPTIONS (phase 1) –– */
.options-grid {
display: flex;
flex-direction: column;
gap: 10px;
margin-bottom: 32px;
}

.option-card {
border: 1.5px solid var(–border);
padding: 16px 20px;
cursor: pointer;
transition: all 0.15s;
display: flex;
align-items: center;
gap: 16px;
background: transparent;
text-align: left;
width: 100%;
font-family: ‘Syne’, sans-serif;
}

.option-card:hover { border-color: var(–ink); background: rgba(28,24,20,0.02); }
.option-card.selected { border-color: var(–accent); background: var(–accent-light); }

.opt-letter {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
font-weight: 500;
color: var(–muted);
min-width: 16px;
flex-shrink: 0;
}

.option-card.selected .opt-letter { color: var(–accent); }

.opt-text {
font-size: 0.93rem;
font-weight: 600;
line-height: 1.4;
color: var(–ink);
}

/* –– FREQUENCY SCALE –– */
.freq-statement {
margin-bottom: 28px;
padding-bottom: 28px;
border-bottom: 1px solid var(–border);
}

.freq-statement:last-child {
border-bottom: none;
margin-bottom: 0;
padding-bottom: 0;
}

.freq-label {
font-size: 0.95rem;
font-weight: 600;
line-height: 1.5;
color: var(–ink);
margin-bottom: 14px;
}

.freq-scale {
display: flex;
gap: 6px;
}

.freq-btn {
flex: 1;
border: 1.5px solid var(–border);
background: transparent;
padding: 10px 4px 8px;
cursor: pointer;
transition: all 0.15s;
font-family: ‘DM Mono’, monospace;
font-size: 9px;
letter-spacing: 0.5px;
color: var(–muted);
text-align: center;
line-height: 1.3;
display: flex;
flex-direction: column;
align-items: center;
gap: 4px;
}

.freq-btn .freq-num {
font-size: 13px;
font-weight: 500;
color: var(–ink);
font-family: ‘Playfair Display’, serif;
font-style: italic;
}

.freq-btn:hover { border-color: var(–ink); }
.freq-btn.selected-1 { border-color: var(–freq-1); background: rgba(61,90,128,0.08); color: var(–freq-1); }
.freq-btn.selected-1 .freq-num { color: var(–freq-1); }
.freq-btn.selected-2 { border-color: var(–freq-2); background: rgba(107,140,174,0.08); color: var(–freq-2); }
.freq-btn.selected-2 .freq-num { color: var(–freq-2); }
.freq-btn.selected-3 { border-color: var(–freq-3); background: rgba(233,168,37,0.08); color: var(–freq-3); }
.freq-btn.selected-3 .freq-num { color: var(–freq-3); }
.freq-btn.selected-4 { border-color: var(–freq-4); background: rgba(212,115,42,0.08); color: var(–freq-4); }
.freq-btn.selected-4 .freq-num { color: var(–freq-4); }
.freq-btn.selected-5 { border-color: var(–freq-5); background: rgba(200,75,47,0.08); color: var(–freq-5); }
.freq-btn.selected-5 .freq-num { color: var(–freq-5); }

.freq-labels-row {
display: flex;
justify-content: space-between;
margin-top: 6px;
padding: 0 2px;
}

.freq-label-end {
font-family: ‘DM Mono’, monospace;
font-size: 9px;
color: var(–muted);
letter-spacing: 0.5px;
}

/* –– NAV –– */
.q-nav {
display: flex;
justify-content: flex-end;
padding-top: 8px;
}

.btn-next {
background: var(–ink);
color: var(–bg);
border: none;
font-family: ‘Syne’, sans-serif;
font-weight: 700;
font-size: 13px;
letter-spacing: 1px;
text-transform: uppercase;
padding: 14px 32px;
cursor: pointer;
transition: all 0.18s;
opacity: 0;
pointer-events: none;
}

.btn-next.visible { opacity: 1; pointer-events: all; }
.btn-next:hover { background: var(–accent); }

/* –– RESULT –– */
.result-eyebrow {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 12px;
}

.result-emoji {
font-size: 64px;
line-height: 1;
margin-bottom: 16px;
display: block;
animation: popIn 0.5s cubic-bezier(0.36,0.07,0.19,0.97) both;
}

@keyframes popIn {
from { opacity: 0; transform: scale(0.5) rotate(-15deg); }
to { opacity: 1; transform: scale(1) rotate(0deg); }
}

.result-name {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2rem, 6vw, 2.8rem);
line-height: 1.1;
margin-bottom: 20px;
color: var(–ink);
}

.result-desc {
font-size: 0.93rem;
line-height: 1.8;
color: #5a5550;
font-weight: 400;
margin-bottom: 28px;
}

.result-divider {
height: 1px;
background: var(–border);
margin: 24px 0;
}

.traits-wrap {
display: flex;
flex-wrap: wrap;
gap: 8px;
margin-bottom: 28px;
}

.trait {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.5px;
padding: 5px 12px;
border: 1.5px solid var(–border);
color: var(–ink);
}

/* –– GLOSSARY –– */
.glossary-section {
background: #faf7f0;
border: 1px solid var(–border);
padding: 24px;
margin-bottom: 28px;
}

.glossary-title {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 18px;
}

.glossary-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
gap: 12px;
}

.glossary-item {
padding-bottom: 12px;
border-bottom: 1px solid var(–border);
}

.gloss-fr { font-weight: 700; font-size: 0.88rem; color: var(–ink); }
.gloss-en { font-family: ‘DM Mono’, monospace; font-size: 10px; color: var(–muted); margin-top: 2px; }

.result-actions { display: flex; gap: 12px; flex-wrap: wrap; }

.btn-restart {
background: var(–ink);
color: var(–bg);
border: none;
font-family: ‘Syne’, sans-serif;
font-weight: 700;
font-size: 13px;
letter-spacing: 1px;
text-transform: uppercase;
padding: 14px 32px;
cursor: pointer;
transition: all 0.18s;
}
.btn-restart:hover { background: var(–accent); }

</style>
</head>
<body>
<div class="container">

<!-- INTRO -->

<div class="screen active" id="screen-intro">
  <div class="card">
    <div class="intro-eyebrow">French 3 · La Technologie</div>
    <h1 class="intro-title">Quel est ton <em>profil</em> numérique?</h1>
    <p class="intro-body">Réponds honnêtement — il n'y a pas de bonnes ou mauvaises réponses. Tu vas découvrir comment et pourquoi tu utilises la technologie.</p>
    <div class="intro-pills">
      <span class="pill">🇫🇷 En français</span>
      <span class="pill">⏱ ~5 minutes</span>
