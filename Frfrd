    <div id="questionBody"></div>
    <div class="q-nav">
      <button class="btn-next" id="btnNext" onclick="advance()">Continuer →</button>
    </div>
  </div>
</div>

<!-- RESULT -->

<div class="screen" id="screen-result">
  <div class="card" id="resultCard"></div>
</div>

</div>

