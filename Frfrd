      { text: 'Je poste des photos ou des vidéos numériques de ma vie quotidienne.', scores: { diariste: 5, reseauteur: 3, connecteur: 1 } },
      { text: 'Je préfère envoyer un texto plutôt qu\'afficher quelque chose publiquement.', scores: { connecteur: 5, diariste: 1, reseauteur: 1 } },
      { text: 'Mon profil en ligne reflète vraiment qui je suis.', scores: { reseauteur: 5, diariste: 3, connecteur: 1 } }
    ],
    personas: ['connecteur', 'reseauteur', 'diariste']
  },
  B: {
    label: 'Expression Créative',
    statements: [
      { text: 'Je consacre du temps à créer des choses pour les partager en ligne.', scores: { createur: 5, artiste: 2 } },
      { text: 'Je crée même si personne ne voit ce que j\'enregistre ou je fais.', scores: { artiste: 5, createur: 1 } },
      { text: 'Le nombre de vues est important pour moi quand je poste.', scores: { createur: 5, artiste: 1 } }
    ],
    personas: ['createur', 'artiste']
  },
  C: {
    label: 'Savoir & Engagement',
    statements: [
      { text: 'J\'affiche mon opinion sur des sujets importants sur les réseaux sociaux.', scores: { engage: 5, geek: 1 } },
      { text: 'Je télécharge des applis ou des outils numériques puissants pour apprendre.', scores: { geek: 5, engage: 2 } },
      { text: 'Je consacre du temps à des causes qui font partie de mes valeurs.', scores: { engage: 5, geek: 1 } }
    ],
    personas: ['engage', 'geek']
  },
  D: {
    label: 'Loisirs & Évasion',
    statements: [
      { text: 'Je me sers des jeux vidéo pour me détendre.', scores: { joueur: 5, evade: 2, viral: 1, travailleur: 0 } },
      { text: 'Je fais défiler mon feed et j\'envoie des choses drôles à mes amis.', scores: { viral: 5, evade: 2, joueur: 1, travailleur: 0 } },
      { text: 'J\'utilise des applis fiables pour organiser et planifier ma vie.', scores: { travailleur: 5, joueur: 1, viral: 0, evade: 0 } },
      { text: 'Le divertissement numérique m\'aide à presque oublier ma journée.', scores: { evade: 5, viral: 2, joueur: 2, travailleur: 0 } }
    ],
    personas: ['evade', 'joueur', 'viral', 'travailleur']
  }
};

// ---- STATE ----
let phase = 1;
let p1Index = 0;
let bucketVotes = { A: 0, B: 0, C: 0, D: 0 };
let currentBranch = null;
let freqIndex = 0;
let freqScores = {};
let p1Selection = null;
let freqSelections = [];
let totalSteps = 0;
let currentStep = 0;

function startQuiz() {
  show('screen-quiz');
  phase = 1;
  p1Index = 0;
  bucketVotes = { A: 0, B: 0, C: 0, D: 0 };
  renderPhase1();
}

function renderPhase1() {
  const q = PHASE1[p1Index];
  currentStep = p1Index + 1;
  totalSteps = 2 + (currentBranch ? BRANCHES[currentBranch].statements.length : 5);

  setProgress(currentStep, 7);
  document.getElementById('qType').textContent = 'Question ' + currentStep + ' sur 2';
  document.getElementById('qText').textContent = q.text;
  p1Selection = null;
  hideContinue();

  const body = document.getElementById('questionBody');
  body.innerHTML = '';
  const grid = document.createElement('div');
  grid.className = 'options-grid';

  q.options.forEach((opt, i) => {
    const letters = ['A', 'B', 'C', 'D'];
    const btn = document.createElement('button');
    btn.className = 'option-card';
    btn.innerHTML = `<span class="opt-letter">${letters[i]}</span><span class="opt-text">${opt.text}</span>`;
    btn.onclick = () => {
      document.querySelectorAll('.option-card').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      p1Selection = opt.vote;
      showContinue();
    };
    grid.appendChild(btn);
  });

  body.appendChild(grid);
}

function renderFreqPhase() {
  const branch = BRANCHES[currentBranch];
  const statements = branch.statements;

  freqSelections = new Array(statements.length).fill(null);
  freqScores = {};
  branch.personas.forEach(p => freqScores[p] = 0);

  totalSteps = 2 + statements.length;
  setProgress(3, totalSteps);

  document.getElementById('qType').textContent = 'Réponds à chaque phrase';
  document.getElementById('qText').textContent = branch.label + ' — ' + branch.personas.length + ' profils possibles';
  hideContinue();

  const body = document.getElementById('questionBody');
  body.innerHTML = '';

  statements.forEach((stmt, si) => {
    const block = document.createElement('div');
    block.className = 'freq-statement';

    const lbl = document.createElement('div');
    lbl.className = 'freq-label';
    lbl.textContent = stmt.text;
    block.appendChild(lbl);

    const scale = document.createElement('div');
    scale.className = 'freq-scale';

    FREQ_LABELS.forEach((label, val) => {
      const score = val + 1;
      const btn = document.createElement('button');
      btn.className = 'freq-btn';
      btn.innerHTML = `<span class="freq-num">${score}</span>${label}`;
      btn.onclick = () => {
        block.querySelectorAll('.freq-btn').forEach(b => {
          b.className = 'freq-btn';
        });
        btn.className = `freq-btn selected-${score}`;
        freqSelections[si] = { score, weights: stmt.scores };
        checkFreqComplete(statements.length);
      };
      scale.appendChild(btn);
    });

    block.appendChild(scale);

    const row = document.createElement('div');
    row.className = 'freq-labels-row';
    row.innerHTML = '<span class="freq-label-end">Jamais</span><span class="freq-label-end">Toujours</span>';
    block.appendChild(row);

    body.appendChild(block);
  });
}

function checkFreqComplete(total) {
  const allAnswered = freqSelections.every(s => s !== null);
  if (allAnswered) showContinue();
}

function advance() {
  if (phase === 1) {
    bucketVotes[p1Selection]++;
    p1Index++;
    if (p1Index < PHASE1.length) {
      renderPhase1();
    } else {
      // Determine bucket
      const bucket = Object.entries(bucketVotes).sort((a,b) => b[1]-a[1])[0][0];
      currentBranch = bucket;
      phase = 2;
      renderFreqPhase();
    }
  } else {
    // Score frequency responses
    freqSelections.forEach(sel => {
      if (!sel) return;
      Object.entries(sel.weights).forEach(([persona, weight]) => {
        if (freqScores[persona] !== undefined) {
          freqScores[persona] += sel.score * weight;
        }
      });
    });

    const winner = Object.entries(freqScores).sort((a,b) => b[1]-a[1])[0][0];
    showResult(winner);
  }
}

function showResult(personaKey) {
  const p = PERSONAS[personaKey];
  show('screen-result');

  const card = document.getElementById('resultCard');
  card.innerHTML = `
    <div class="result-eyebrow">Ton profil numérique</div>
    <span class="result-emoji">${p.emoji}</span>
    <div class="result-name">${p.name}</div>
    <div class="result-desc">${p.desc}</div>
    <div class="traits-wrap">${p.traits.map(t => `<span class="trait">${t}</span>`).join('')}</div>
    <div class="result-divider"></div>
    <div class="glossary-section">
      <div class="glossary-title">Glossaire · Vocabulary</div>
      <div class="glossary-grid">
        ${p.glossary.map(g => `<div class="glossary-item"><div class="gloss-fr">${g.fr}</div><div class="gloss-en">${g.en}</div></div>`).join('')}
      </div>
    </div>
    <div class="result-actions">
      <button class="btn-restart" onclick="restart()">↺ Recommencer</button>
    </div>
  `;
}

function restart() {
  phase = 1;
  p1Index = 0;
  bucketVotes = { A: 0, B: 0, C: 0, D: 0 };
  currentBranch = null;
  freqIndex = 0;
  freqScores = {};
  p1Selection = null;
  freqSelections = [];
  show('screen-intro');
}

function show(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function showContinue() {
  document.getElementById('btnNext').classList.add('visible');
}

function hideContinue() {
  document.getElementById('btnNext').classList.remove('visible');
}

function setProgress(current, total) {
  const pct = Math.round((current / total) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = `Étape ${current} sur ${total}`;
}
</script>

